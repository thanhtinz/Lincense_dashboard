# =============================================================================
# LICENSE PLATFORM — Production Environment
# Run: node ../license-platform/scripts/setup.js  to auto-generate secrets
# =============================================================================

# ── Domain ───────────────────────────────────────────────────────────────────
DOMAIN=license.yourdomain.com

# ── Database ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 24
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_128_hex_chars
JWT_EXPIRES_IN=8h

# ── RSA Keys (License Key Signing) ───────────────────────────────────────────
# Generated by scripts/setup.js — paste with \n line breaks
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END RSA PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_KEY_HERE\n-----END PUBLIC KEY-----"

# ── AES Master Key ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_MASTER_KEY=CHANGE_ME_64_hex_chars

# ── Admin Account (seed) ──────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_password
ADMIN_NAME=Super Admin

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_nextauth_secret

# ── Security tuning ───────────────────────────────────────────────────────────
RATE_LIMIT_VERIFY_RPM=10
NONCE_WINDOW_SECONDS=300

# ── Backup to S3 / Cloudflare R2 (optional) ──────────────────────────────────
BACKUP_S3_BUCKET=my-license-backups
BACKUP_AWS_KEY=
BACKUP_AWS_SECRET=
BACKUP_AWS_REGION=ap-southeast-1
# For Cloudflare R2, set endpoint in backup.sh
