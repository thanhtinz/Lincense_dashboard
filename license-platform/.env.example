# ===========================================
# LICENSE PLATFORM — Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# --- App ---
NODE_ENV=development
PORT=3001
API_BASE_URL=https://license.yourdomain.com

# --- Database ---
DATABASE_URL=postgresql://license_user:strongpassword@localhost:5432/license_platform

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- JWT (Admin Auth) ---
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_generate_with_crypto_randomBytes_64
JWT_EXPIRES_IN=8h

# --- RSA Keys (License Key Signing) ---
# Generate:
#   openssl genrsa -out rsa_private.pem 2048
#   openssl rsa -in rsa_private.pem -pubout -out rsa_public.pem
# Then paste content here (replace newlines with \n)
RSA_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nPASTE_YOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----"
RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nPASTE_YOUR_KEY_HERE\n-----END PUBLIC KEY-----"

# --- AES Master Key (encrypt runtime keys in DB) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AES_MASTER_KEY=CHANGE_ME_64_hex_chars_here

# --- Admin First User (seed) ---
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=CHANGE_ME_strong_password
ADMIN_NAME=Super Admin

# --- Security ---
# Max verify requests per IP per minute
RATE_LIMIT_VERIFY_RPM=10
# Grace period hours when license server unreachable
GRACE_PERIOD_HOURS=24
# Replay attack window (seconds)
NONCE_WINDOW_SECONDS=300

# --- Optional: Email Notifications ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your_app_password
EMAIL_FROM="License Platform <noreply@yourdomain.com>"
