{
  "name": "@yourcompany/license-sdk",
  "version": "1.0.0",
  "description": "License Platform SDK — integrate license verification into any Node.js/Next.js product",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": ["license", "verification", "drm"],
  "license": "UNLICENSED",
  "private": false,
  "dependencies": {
    "prisma": "^5.10.0",
    "@prisma/client": "^5.10.0"
  },
  "peerDependencies": {
    "next": ">=13.0.0"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "@types/node": "^20.12.7"
  }
}
